{
  "name": "@jibidieuw/dexes",
  "version": "0.1.0",
  "description": "SDK for interacting with DEXES protocols (Web3PGP & Web3Sign) based on Ethereum and using Viem and OpenPGP",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cryptogram/dexes.git"
  },
  "homepage": "https://github.com/cryptogram/dexes",
  "bugs": {
    "url": "https://github.com/cryptogram/dexes/issues"
  },
  "keywords": [
    "ethereum",
    "web3",
    "openpgp",
    "cryptography",
    "blockchain",
    "pki",
    "edi",
    "viem",
    "typescript"
  ],
  "author": "Cryptogram Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:contracts": "cd ../../contracts && forge build",
    "update-abis": "npm run build:contracts && node scripts/update-abis.js",
    "clean": "find . -name '*.js' -o -name '*.d.ts' -o -name '*.map' | grep -E '(src|__tests__)' | xargs rm -f",
    "clean:broadcasts": "rm -rf ../../contracts/broadcast/DeployTestEnvironment.s.sol",
    "typecheck": "tsc --noEmit",
    "test": "npm run update-abis && node scripts/test-orchestrator.js",
    "test:dev": "jest --watch",
    "test:watch": "jest --watch",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=integration",
    "test:integration": "npm run test",
    "test:web3sign": "npm run update-abis && node scripts/test-orchestrator.js -- --testPathPattern='web3sign'",
    "test:web3pgp": "npm run update-abis && node scripts/test-orchestrator.js -- --testPathPattern='web3pgp'",
    "test:all": "npm run test:unit && npm run test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/p-limit": "^2.2.0",
    "dotenv": "^16.6.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "openpgp": "^6.1.0",
    "p-limit": "^2.3.0",
    "viem": "*"
  }
}
