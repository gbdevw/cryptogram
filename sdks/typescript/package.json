{
  "name": "dexes",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p .",
    "build:contracts": "cd ../../contracts && forge build",
    "clean": "find . -name '*.js' -o -name '*.d.ts' -o -name '*.map' | grep -E '(src|__tests__)' | xargs rm -f",
    "clean:broadcasts": "rm -rf ../../contracts/broadcast/DeployTestEnvironment.s.sol",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=integration",
    "test:integration": "npm run build:contracts && jest --config jest.integration.config.js",
    "test:all": "npm run test:unit && npm run test:integration"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/p-limit": "^2.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "openpgp": "^6.1.0",
    "p-limit": "^3.1.0",
    "viem": "^2.21.0"
  },
  "description": ""
}
